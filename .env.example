# Application
APP_NAME=visual-search-engine
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Embedding Model
EMBEDDING_MODEL_NAME=google/siglip-base-patch16-224
EMBEDDING_DEVICE=cpu  # set to "cuda" if you have a GPU
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DIMENSION=768

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=images
QDRANT_DISTANCE_METRIC=Cosine

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL_SECONDS=3600

# Authentication
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Monitoring
PROMETHEUS_PORT=9000
ENABLE_METRICS=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
